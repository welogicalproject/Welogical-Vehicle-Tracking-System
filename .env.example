# Application Settings
APP_NAME="Vehicle Tracking System Backend"
APP_ENV=development
DEBUG=true
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS="http://localhost:3000,http://127.0.0.1:3000"

# Database Settings
# Replace with your PostgreSQL credentials. 
# Sync database URL (for Alembic and sync connections)
DATABASE_URL=
ASYNC_DATABASE_URL=

# Logging Settings
LOG_LEVEL=INFO

# Google Routes API Settings
GOOGLE_ROUTES_ENABLED=true
GOOGLE_ROUTES_API_KEY=AIzaS
SAVE_RAW_GOOGLE_RESPONSES=false
GOOGLE_ROUTES_TIMEOUT_SECONDS=5
GOOGLE_ROUTES_MONTHLY_LIMIT=9500
GOOGLE_ROUTES_WARNING_THRESHOLD=8000

